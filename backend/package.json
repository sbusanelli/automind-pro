{
  "name": "automind-backend",
  "version": "1.0.0",
  "description": "AutoMind Backend - Autonomous AI operations system",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=src/tests/unit",
    "test:integration": "jest --testPathPattern=src/tests/integration",
    "test:e2e": "jest --testPathPattern=src/tests/e2e",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist coverage",
    "security:audit": "npm audit",
    "security:sast": "semgrep --config=security/sast-config.yml src/",
    "db:migrate": "node dist/database/migrate.js",
    "db:seed": "node dist/database/seed.js"
  },
  "dependencies": {
    "@pinecone-database/pinecone": "^3.0.0",
    "@types/sqlite3": "^5.1.0",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "cors": "^2.8.6",
    "cron": "^3.1.0",
    "dotenv": "^16.3.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "openai": "^4.20.0",
    "pg": "^8.11.0",
    "redis": "^4.6.0",
    "redis-memory-server": "^0.16.1",
    "socket.io": "^4.7.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "typescript": "^5.2.2",
    "uuid": "^11.1.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.8.0",
    "@types/pg": "^8.10.0",
    "@types/selenium-webdriver": "^4.35.5",
    "@types/supertest": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "axios": "^1.16.0",
    "eslint": "^8.50.0",
    "eslint-plugin-security": "^1.7.0",
    "jest": "^29.7.0",
    "minimatch": "^10.2.5",
    "nodemon": "^3.0.0",
    "prettier": "^3.0.0",
    "selenium-webdriver": "^4.43.0",
    "supertest": "^6.3.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
